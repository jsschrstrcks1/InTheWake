#!/bin/bash
# ============================================================================
# Pre-commit hook — validate staged ship pages
#
# Runs admin/validate-ship-page.sh (the canonical ship validator) on every
# ship-page HTML file that is staged for commit. Blocks the commit if any
# file produces validator errors (exit code 1).
#
# Enable for this clone with:
#   git config core.hooksPath .githooks
#
# Skip for a single commit with:
#   git commit --no-verify
# (Don't make this a habit — the rule exists because the hook caught real
# drift on every ship in the RCL fleet at least once.)
#
# Exit codes propagated from the validator:
#   0 = pass
#   1 = errors → commit blocked
#   2 = warnings only → commit allowed (validator treats this as success)
#
# Soli Deo Gloria
# ============================================================================

set -u

REPO_ROOT="$(git rev-parse --show-toplevel)"
VALIDATOR="$REPO_ROOT/admin/validate-ship-page.sh"

if [ ! -x "$VALIDATOR" ] && [ ! -f "$VALIDATOR" ]; then
    echo "pre-commit: ship validator not found at $VALIDATOR — skipping ship checks"
    exit 0
fi

# Collect staged ship pages: anything under ships/<line>/<slug>.html.
# Excludes ships/<line>/index.html and ships/<line>/venues.html (hub pages,
# not ship pages — they fail ship checks by design).
mapfile -t SHIP_FILES < <(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '^ships/[^/]+/[^/]+\.html$' \
        | grep -Ev '/(index|venues)\.html$' \
        || true
)

if [ "${#SHIP_FILES[@]}" -eq 0 ]; then
    exit 0
fi

echo "pre-commit: validating ${#SHIP_FILES[@]} ship page(s)…"

FAILED=0
for f in "${SHIP_FILES[@]}"; do
    full="$REPO_ROOT/$f"
    if [ ! -f "$full" ]; then
        # Staged a deletion or rename source — skip.
        continue
    fi
    # Run quietly; only surface output on failure.
    out=$(bash "$VALIDATOR" "$full" 2>&1)
    code=$?
    if [ $code -eq 1 ]; then
        FAILED=$((FAILED + 1))
        echo "─── $f ──────────────────────────────────────────────"
        echo "$out" | tail -40
    fi
done

if [ "$FAILED" -gt 0 ]; then
    echo ""
    echo "pre-commit: $FAILED ship page(s) failed validation. Commit blocked."
    echo "  Re-run on a single file:  bash admin/validate-ship-page.sh <file>"
    echo "  Bypass (use sparingly):   git commit --no-verify"
    exit 1
fi

echo "pre-commit: ${#SHIP_FILES[@]} ship page(s) passed."
exit 0
