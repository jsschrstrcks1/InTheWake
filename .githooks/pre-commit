#!/bin/bash
# ============================================================================
# Pre-commit hook — v3 regression-mode validation for staged ship pages.
#
# Two checks, in order:
#   1. X2 lock check  (admin/ship-lock.cjs check-paths)
#        Rejects commits to a ship/<line>/ that another branch has locked.
#   2. X3 regression diff  (admin/check-ship-regression.cjs)
#        Runs validate-ship-page.js --json-output on each staged ship page,
#        compares failure codes against audit-reports/ship-validation-dashboard.json,
#        blocks the commit iff a NEW failure code appeared (regression).
#        Pre-existing failures DO NOT block — v3 work is incremental.
#
# Enable for this clone:
#   git config core.hooksPath .githooks
#
# Skip for a single commit (use sparingly):
#   git commit --no-verify
#
# Soli Deo Gloria
# ============================================================================

set -u

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Skip during merge / rebase / cherry-pick — the staged set then contains
# everything the upstream author already shipped, and the per-file checks
# below would re-flag pre-existing failures as if this commit introduced
# them. CI is the right place to verify cross-branch state. The hook
# remains active for normal feature commits and for amend.
if [ -f "$REPO_ROOT/.git/MERGE_HEAD" ] || \
   [ -d "$REPO_ROOT/.git/rebase-merge" ] || \
   [ -d "$REPO_ROOT/.git/rebase-apply" ] || \
   [ -f "$REPO_ROOT/.git/CHERRY_PICK_HEAD" ]; then
    echo "pre-commit: merge/rebase/cherry-pick detected — skipping per-file checks."
    exit 0
fi

LOCK_CLI="$REPO_ROOT/admin/ship-lock.cjs"
REGRESSION_CLI="$REPO_ROOT/admin/check-ship-regression.cjs"
IMAGE_REUSE_CLI="$REPO_ROOT/admin/check-image-reuse.cjs"
VOYAGE_PACK_PDF_CHECK="$REPO_ROOT/admin/scripts/voyage-pack-pdf-build.sh"
FACTCHECK_GATE="$REPO_ROOT/admin/scripts/factcheck-gate.sh"

mapfile -t SHIP_FILES < <(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '^ships/[^/]+/[^/]+\.html$' \
        | grep -Ev '/(index|venues|quiz)\.html$' \
        || true
)

mapfile -t IMAGE_TARGETS < <(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '\.(webp|jpe?g|png|gif|avif)$|^(ships|ports|articles|authors)/.+\.html$' \
        || true
)

mapfile -t VOYAGE_PACK_MD < <(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '^admin/voyage-packs/v[0-9].*\.md$' \
        || true
)

if [ "${#SHIP_FILES[@]}" -eq 0 ] && [ "${#IMAGE_TARGETS[@]}" -eq 0 ] && [ "${#VOYAGE_PACK_MD[@]}" -eq 0 ]; then
    exit 0
fi

# 1. X2 lock check (ship pages)
if [ -f "$LOCK_CLI" ] && [ "${#SHIP_FILES[@]}" -gt 0 ]; then
    if ! node "$LOCK_CLI" check-paths "${SHIP_FILES[@]}"; then
        echo "pre-commit: lock conflict. Commit blocked."
        exit 1
    fi
fi

# 2. X3 regression diff (ship pages)
if [ -f "$REGRESSION_CLI" ] && [ "${#SHIP_FILES[@]}" -gt 0 ]; then
    echo "pre-commit: regression-checking ${#SHIP_FILES[@]} ship page(s)…"
    if ! node "$REGRESSION_CLI" "${SHIP_FILES[@]}"; then
        echo ""
        echo "pre-commit: regression detected. Commit blocked."
        echo "  Re-run:    node admin/check-ship-regression.cjs <file>"
        echo "  Bypass:    git commit --no-verify  (use sparingly)"
        exit 1
    fi
fi

# 3. Image-reuse guardrail (any image add or HTML referencing images).
#    Skill: .claude/skills/image-reuse-guardrail/SKILL.md
if [ -f "$IMAGE_REUSE_CLI" ] && [ "${#IMAGE_TARGETS[@]}" -gt 0 ]; then
    echo "pre-commit: image-reuse-checking ${#IMAGE_TARGETS[@]} target(s)…"
    if ! node "$IMAGE_REUSE_CLI" "${IMAGE_TARGETS[@]}"; then
        # check-image-reuse.cjs prints its own block message
        exit 1
    fi
fi

# 4. Voyage-pack PDF staleness check.
#    When a pack .md is staged, the corresponding .pdf must exist and be
#    newer than the .md. The PDF is the paid deliverable; a stale or missing
#    PDF means buyers receive an outdated document.
#    Rebuild with: admin/scripts/voyage-pack-pdf-build.sh
if [ -f "$VOYAGE_PACK_PDF_CHECK" ] && [ "${#VOYAGE_PACK_MD[@]}" -gt 0 ]; then
    echo "pre-commit: voyage-pack PDF staleness check (${#VOYAGE_PACK_MD[@]} pack source(s) staged)…"
    if ! bash "$VOYAGE_PACK_PDF_CHECK" --check; then
        echo ""
        echo "pre-commit: stale or missing Voyage Pack PDF(s). Commit blocked."
        echo "  Rebuild:   admin/scripts/voyage-pack-pdf-build.sh"
        echo "  Bypass:    git commit --no-verify  (only when intentionally shipping a .md change without a regenerated .pdf)"
        exit 1
    fi
fi

# 5. Voyage-pack factual-claim gate (original-research skill).
#    When a pack .md is staged, a fresh complete .factcheck.json sidecar must
#    exist citing primary sources for every factual claim. Enforces the doctrine
#    at .claude/skills/original-research/ORIGINAL-RESEARCH.md.
#    Built 2026-05-30 after an audit found ~50 confabulated facts across 11 packs.
#    Soli Deo Gloria — the closing requires the contents be true.
if [ -f "$FACTCHECK_GATE" ] && [ "${#VOYAGE_PACK_MD[@]}" -gt 0 ]; then
    if ! bash "$FACTCHECK_GATE"; then
        # factcheck-gate.sh prints its own block message and remediation steps
        exit 1
    fi
fi

# 6. no-getbets hard ban — the string "getbets" (case-insensitive) must
#    never appear in any production-facing file. Skill rationale:
#    .claude/skills/no-getbets/SKILL.md
#    Exempt paths (documentation about the ban): .claude/skills/no-getbets/,
#    .claude/hooks/no-getbets-*, .claude/standards/no-getbets*,
#    .githooks/pre-commit (this file), CLAUDE.md, SKILLS.md, AGENT.md,
#    audit-reports/, admin/check-no-getbets*. Exemptions MUST mirror those
#    in .claude/hooks/no-getbets-guard.js EXEMPT_PATH_PATTERNS.
mapfile -t PRODUCTION_FILES < <(
    git diff --cached --name-only --diff-filter=ACMR \
        | grep -Ev '^\.claude/(skills/no-getbets/|hooks/no-getbets-|standards/no-getbets)' \
        | grep -Ev '^\.githooks/pre-commit$' \
        | grep -Ev '^(audit-reports|node_modules|\.git)/' \
        | grep -Ev '^admin/check-no-getbets' \
        | grep -Ev '^admin/seo/' \
        | grep -Ev '^(CLAUDE|SKILLS|AGENT)\.md$' \
        || true
)
if [ "${#PRODUCTION_FILES[@]}" -gt 0 ]; then
    GETBETS_HITS=()
    for f in "${PRODUCTION_FILES[@]}"; do
        if [ -f "$REPO_ROOT/$f" ] && grep -liq 'getbets' "$REPO_ROOT/$f"; then
            GETBETS_HITS+=("$f")
        fi
    done
    if [ "${#GETBETS_HITS[@]}" -gt 0 ]; then
        echo ""
        echo "pre-commit: HARD BAN — 'getbets' string detected in production file(s):"
        for h in "${GETBETS_HITS[@]}"; do echo "  - $h"; done
        echo ""
        echo "  cruisinginthewake.com does not reference getbets.us. See:"
        echo "    .claude/skills/no-getbets/SKILL.md"
        echo ""
        echo "  Bypass (only when intentionally editing ban-documentation files):"
        echo "    git commit --no-verify"
        exit 1
    fi
fi

exit 0
