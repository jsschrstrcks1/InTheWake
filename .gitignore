# Extracted archives (temporary working directory)
old-files-extracted/

# macOS Finder metadata (never useful in the repo)
.DS_Store
**/.DS_Store

# Generated audit reports (post-commit hook output)
admin/reports/last-commit-audit.txt

# Claude Code TypeScript cache
.claude/tsc-cache/
node_modules/
admin/validation-warnings.log
admin/.port-image-hashes.json

# Playwright test artifacts
test-results/
playwright-report/

# Python bytecode and cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Backup and temporary files
*.bak
*.tmp
*.old
*.orig
*.swp
*~

# Venue photo originals and previews (only processed WebP is committed)
assets/images/restaurants/originals/
assets/images/restaurants/previews/

# Environment and secrets (prevent accidental commits)
.env
.env.local
.env.*.local
*.pem
*.key
secrets.*
credentials.*

# beta template-generator scratch output
tools/_genbeta*-out/

# beta4 template builder scratch output
tools/_beta4-build/

# Boardroom operator-private outputs (hard rule #5 — never commit)
.private/
admin/jerusha-src/
